            self.wm.mark_failed(w["address"], "s8"); return False

    # ══════════════════════════════════════════════════════════════════════════
    # STEP 9 — AyniLabs Swap + Supply
    # ══════════════════════════════════════════════════════════════════════════
    def step9(self, w: dict, force=False):
        self._header("🔁", "Step 9: AyniLabs — zkLTC→wzkLTC + Supply", w)
        if self.wm.is_done(w["address"], "s9") and not force:
            warn("Already completed."); return True

        amt = rand_amt(0.0001, 0.0005)
        console.print(f"  [dim]Amount: {amt} zkLTC[/dim]")

        with console.status("[cyan]  Scanning AyniLabs page...[/cyan]", spinner="dots"):
            human_delay(2, 4)
            addrs = fetch_contracts("https://aynilabs.xyz/dashboard/")
            ayni  = next((a for a in addrs if a.lower() != ZKLTC_TOKEN.lower()), None)

        AYNI_ABI = [
            {"inputs":[{"name":"amount","type":"uint256"}],"name":"wrap",
             "outputs":[],"stateMutability":"nonpayable","type":"function"},
            {"inputs":[{"name":"amount","type":"uint256"}],"name":"supply",
             "outputs":[],"stateMutability":"nonpayable","type":"function"},
            {"inputs":[{"name":"amount","type":"uint256"}],"name":"deposit",
             "outputs":[],"stateMutability":"nonpayable","type":"function"},
        ]

        if not ayni or not self.chain.ok:
            fail("AyniLabs contract not found — manual required")
            info("→ Visit: https://aynilabs.xyz/dashboard/")
            self.wm.mark_failed(w["address"], "s9"); return False

        # Approve zkLTC
        info("Approving zkLTC for AyniLabs...")
        ap_ok, ap_res = self.chain.approve(
            w["private_key"], ZKLTC_TOKEN, ayni, int(amt * 1e18) * 100)

        if not ap_ok:
            fail(f"Approve failed: {ap_res}")
            self.wm.mark_failed(w["address"], "s9"); return False

        ok(f"Approved! TX: {ap_res[:16]}...")
        human_delay(2, 3)

        # Wrap
        info("Wrapping zkLTC → wzkLTC...")
        w_ok, w_res = self.chain.contract_tx(
            w["private_key"], ayni, AYNI_ABI, "wrap", [int(amt*1e18)], gas=200_000)
        if not w_ok:
            fail(f"Wrap failed: {w_res}")
            self.wm.mark_failed(w["address"], "s9"); return False

        ok(f"Wrapped! TX: {w_res[:16]}...")
        human_delay(2, 3)

        # Supply (fallback to deposit)
        info("Supplying wzkLTC...")
        s_ok, s_res = self.chain.contract_tx(
            w["private_key"], ayni, AYNI_ABI, "supply", [int(amt*1e18)], gas=200_000)
        if not s_ok:
            info("supply() failed, trying deposit()...")
            s_ok, s_res = self.chain.contract_tx(
                w["private_key"], ayni, AYNI_ABI, "deposit", [int(amt*1e18)], gas=200_000)

        if s_ok:
            ok(f"Supplied/Deposited! TX: {s_res[:16]}...")
            info(tx_url(s_res))
            self.wm.mark_done(w["address"], "s9"); return True
        else:
            fail(f"Supply failed: {s_res}")
            self.wm.mark_failed(w["address"], "s9"); return False

    # ══════════════════════════════════════════════════════════════════════════
    # Run all tasks + print summary
    # ══════════════════════════════════════════════════════════════════════════
    ALL_STEPS = [
        ("s1","Step 1: LiteForge Faucet",   "step1"),
        ("s2","Step 2: Lester Labs",         "step2"),
        ("s3","Step 3: Midashand Faucet",    "step3"),
        ("s4","Step 4: Midashand Bet",       "step4"),
        ("s5","Step 5: ONMI Create Token",   "step5"),
        ("s6","Step 6: ONMI Swaps",          "step6"),
        ("s7","Step 7: ONMI Liquidity",      "step7"),
        ("s8","Step 8: ONMI Campaign",       "step8"),
        ("s9","Step 9: AyniLabs",            "step9"),
    ]

    def run_all(self, w: dict, force=False):
        bal = self.chain.balance(w["address"]) if self.chain.ok else 0
        console.print(f"\n[bold cyan]━━━ {short(w['address'])} | Balance: {bal:.5f} tLTC ━━━[/bold cyan]")
        if self.chain.ok and bal < 0.001:
            console.print(Panel(
                "[red bold]⚠ VERY LOW BALANCE!\n[/red bold]"
                "Fund wallet from faucet first:\n"
                "[cyan]https://liteforge.hub.caldera.xyz[/cyan]\n"
                "Or run Step 1 first, wait for tokens, then run all.",
                border_style="red"))

        results = {}
        for tid, name, fn_name in self.ALL_STEPS:
            console.print()
            fn = getattr(self, fn_name)
            results[name] = fn(w, force=force)

        # ── Summary Report ────────────────────────────────────────────────────
        console.print()
        console.print(Panel(
            "\n".join(
                f"  {'[green]✅[/green]' if v else '[red]❌[/red]'} {k}"
                for k, v in results.items()
            ),
            title=f"[bold]📊 Results — {short(w['address'])}[/bold]",
            border_style="green" if all(results.values()) else "yellow"
        ))
        passed = sum(results.values())
        console.print(f"  [bold]{'[green]' if passed==9 else '[yellow]'}{passed}/9 tasks completed[/bold]")


# ─── Menu ─────────────────────────────────────────────────────────────────────
def menu():
    print_banner()
    wm    = WalletManager()
    chain = Chain()
    tasks = Tasks(wm, chain)

    STEP_LIST = [
        ("Step 1: LiteForge Faucet",   tasks.step1),
        ("Step 2: Lester Labs Launch",  tasks.step2),
        ("Step 3: Midashand Faucet",    tasks.step3),
        ("Step 4: Midashand Bet",       tasks.step4),
        ("Step 5: ONMI Create Token",   tasks.step5),
        ("Step 6: ONMI Swaps",          tasks.step6),
        ("Step 7: ONMI Liquidity",      tasks.step7),
        ("Step 8: ONMI Campaign",       tasks.step8),
        ("Step 9: AyniLabs",            tasks.step9),
    ]

    while True:
        console.print(Panel(
            "[cyan]1.[/cyan] Create wallets (unlimited)\n"
            "[cyan]2.[/cyan] List saved wallets\n"
            "[cyan]3.[/cyan] Run ALL tasks — single wallet\n"
            "[cyan]4.[/cyan] Run ALL tasks — ALL wallets\n"
            "[cyan]5.[/cyan] Run a specific step\n"
            "[cyan]6.[/cyan] Force re-run a failed step\n"
            "[cyan]7.[/cyan] Check wallet balances\n"
            "[cyan]8.[/cyan] Reset task status (re-run all)\n"
            "[cyan]0.[/cyan] Exit",
            title="[bold yellow]⚡ MirLite Bot v4.0 — Main Menu[/bold yellow]",
            border_style="cyan", expand=False))

        choice = input(f"\n{Fore.CYAN}  Enter choice: {Style.RESET_ALL}").strip()

        if choice == "1":
            try:
                n = int(input(f"{Fore.YELLOW}  How many wallets? {Style.RESET_ALL}"))
                created = wm.create(n)
                console.print(f"\n[green]✓ Created {n} wallet(s):[/green]")
                for cw in created:
                    console.print(f"  [green]{cw['address']}[/green]")
                console.print(f"\n[bold yellow]⚠ BACKUP {WALLETS_FILE} — contains private keys![/bold yellow]")
            except ValueError: console.print("[red]Invalid number[/red]")

        elif choice == "2":
            if not wm.wallets: console.print("[yellow]No wallets yet.[/yellow]")
            else: wm.show_table()

        elif choice == "3":
            if not wm.wallets: console.print("[red]No wallets. Create some first.[/red]"); continue
            wm.show_table()
            try:
                idx = int(input(f"{Fore.CYAN}  Wallet #: {Style.RESET_ALL}")) - 1
                if 0 <= idx < len(wm.wallets): tasks.run_all(wm.wallets[idx])
                else: console.print("[red]Invalid wallet number[/red]")
            except ValueError: console.print("[red]Invalid input[/red]")

        elif choice == "4":
            if not wm.wallets: console.print("[red]No wallets.[/red]"); continue
            console.print(f"\n[bold yellow]Processing {len(wm.wallets)} wallet(s)...[/bold yellow]")
            for i, w in enumerate(wm.wallets):
                console.print(f"\n[bold magenta]═══ Wallet {i+1}/{len(wm.wallets)} ═══[/bold magenta]")
                tasks.run_all(w)
                if i < len(wm.wallets) - 1:
                    wait = random.randint(45, 120)
                    console.print(f"[dim]Cooling down {wait}s (anti-detection)...[/dim]")
                    time.sleep(wait)
            console.print("\n[bold green]🎉 All wallets processed![/bold green]")

        elif choice in ("5", "6"):
            force = (choice == "6")
            console.print(f"\n{'[yellow]Force re-run mode[/yellow]' if force else ''}")
            for i, (name, _) in enumerate(STEP_LIST):
                console.print(f"  [cyan]{i+1}.[/cyan] {name}")
            try:
                s = int(input(f"\n{Fore.CYAN}  Step #: {Style.RESET_ALL}")) - 1
                if not (0 <= s < len(STEP_LIST)): console.print("[red]Invalid step[/red]"); continue
                if not wm.wallets: console.print("[red]No wallets.[/red]"); continue
                wm.show_table()
                wc = input(f"{Fore.CYAN}  Wallet # (or 'all'): {Style.RESET_ALL}").strip().lower()
                fn = STEP_LIST[s][1]
                if wc == "all":
                    for w in wm.wallets: fn(w, force=force); human_delay(5, 15)
                else:
                    idx = int(wc) - 1
                    if 0 <= idx < len(wm.wallets): fn(wm.wallets[idx], force=force)
                    else: console.print("[red]Invalid wallet[/red]")
            except ValueError: console.print("[red]Invalid input[/red]")

        elif choice == "7":
            if not wm.wallets: console.print("[yellow]No wallets.[/yellow]"); continue
            t = Table(title="💰 Balances", box=box.ROUNDED, style="cyan", header_style="bold magenta")
            t.add_column("#"); t.add_column("Address"); t.add_column("tLTC"); t.add_column("zkLTC"); t.add_column("Done"); t.add_column("Failed")
            with console.status("[cyan]Fetching...[/cyan]", spinner="dots"):
                for i, w in enumerate(wm.wallets):
                    b1 = chain.balance(w["address"])   if chain.ok else 0.0
                    b2 = chain.token_bal(ZKLTC_TOKEN, w["address"]) if chain.ok else 0.0
                    t.add_row(str(i+1), short(w["address"]),
                              f"{b1:.5f}", f"{b2:.4f}",
                              f"{len(w.get('tasks_done',[]))}/9",
                              str(len(w.get("tasks_failed",[]))))
            console.print(t)

        elif choice == "8":
            if not wm.wallets: console.print("[yellow]No wallets.[/yellow]"); continue
            wm.show_table()
            try:
                idx = int(input(f"{Fore.CYAN}  Reset which wallet #? {Style.RESET_ALL}")) - 1
                if 0 <= idx < len(wm.wallets):
                    wm.wallets[idx]["tasks_done"]   = []
                    wm.wallets[idx]["tasks_failed"]  = []
                    wm.save()
                    console.print(f"[green]✓ Wallet {idx+1} task history cleared — will re-run all steps[/green]")
                else: console.print("[red]Invalid[/red]")
            except ValueError: console.print("[red]Invalid[/red]")

        elif choice == "0":
            console.print("[bold yellow]\n  👋 Good luck with the airdrop!\n[/bold yellow]")
            sys.exit(0)
        else:
            console.print("[red]Invalid choice[/red]")

        input(f"\n{Fore.CYAN}  Press Enter to continue...{Style.RESET_ALL}")
        os.system("cls" if os.name == "nt" else "clear")
        print_banner()

if __name__ == "__main__":
    try: menu()
    except KeyboardInterrupt:
        console.print("\n[bold yellow]\n  Interrupted. Bye!\n[/bold yellow]"); sys.exit(0)
