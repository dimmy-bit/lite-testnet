    # ══════════════════════════════════════════════════════════════════════════
    def step8(self, w: dict, force=False):
        self._header("🎯", "Step 8: ONMI Campaign #4441", w)
        if self.wm.is_done(w["address"], "s8") and not force:
            warn("Already completed."); return True

        with console.status("[cyan]  Scanning campaign page...[/cyan]", spinner="dots"):
