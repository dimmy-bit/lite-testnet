                "token": "wzkLTC",
                "amount": str(amount),
                "action": "supply",
                "wallet": wallet["address"],
            }
            resp2 = requests.post(
                "https://aynilabs.xyz/api/supply",
                json=supply_payload, headers=headers, timeout=20
            )
            if resp2.status_code in (200, 201):
                console.print("[green]  ✓ Supply/deposit done![/green]")
            else:
                console.print(f"[yellow]  ⚠ Supply response {resp2.status_code}[/yellow]")
        
        except Exception as e:
            console.print(f"[yellow]⚠ AyniLabs: {str(e)[:60]}[/yellow]")
        
        self.wm.mark_task(wallet["address"], "ayni_swap_supply")
        human_delay(2, 4)

    def run_all_tasks(self, wallet: dict):
        """Run all 9 steps for a single wallet with human-like timing."""
        addr = wallet["address"]
        done = wallet.get("tasks_done", [])
        
        console.print(f"\n[bold cyan]━━━ Running all tasks for: {addr[:12]}...{addr[-8:]} ━━━[/bold cyan]\n")
        
        task_map = [
            ("faucet_liteforge",    self.step1_claim_faucet,    "Step 1: LiteForge Faucet"),
            ("lester_launch",       self.step2_launch_token,    "Step 2: Lester Labs Launch"),
            ("midashand_faucet",    self.step3_midashand_faucet,"Step 3: Midashand Faucet"),
            ("midashand_bet",       self.step4_place_bet,       "Step 4: Midashand Bet"),
            ("onmi_create_token",   self.step5_create_onmi_token,"Step 5: ONMI Create Token"),
            ("onmi_swaps",          self.step6_onmi_swaps,      "Step 6: ONMI Swaps"),
            ("onmi_liquidity",      self.step7_add_liquidity,   "Step 7: ONMI Liquidity"),
            ("onmi_campaign",       self.step8_campaign,        "Step 8: ONMI Campaign"),
            ("ayni_swap_supply",    self.step9_ayni_swap,       "Step 9: AyniLabs"),
        ]
        
        for task_key, task_fn, task_name in task_map:
            if task_key in done:
                console.print(f"[dim]  ✓ {task_name} — already done, skipping[/dim]")
                continue
            task_fn(wallet)
            console.print()
        
        console.print(f"[bold green]✅ All tasks completed for {addr[:12]}...{addr[-8:]}![/bold green]")


