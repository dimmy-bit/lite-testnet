# ─── Chain ───────────────────────────────────────────────────────────────────
class Chain:
    def __init__(self):
        self.w3: Optional[Web3] = None
        for rpc in RPC_URLS:
            try:
                w3 = Web3(Web3.HTTPProvider(rpc, request_kwargs={"timeout":20}))
                if w3.is_connected():
                    self.w3 = w3
                    console.print(f"[green]✓ RPC connected: {rpc}[/green]")
                    return
            except: pass
        console.print("[yellow]⚠ RPC unavailable — on-chain TXs will show manual links[/yellow]")

    @property
    def ok(self): return self.w3 is not None

    def balance(self, addr) -> float:
        try: return float(self.w3.from_wei(self.w3.eth.get_balance(addr), "ether"))
        except: return 0.0

    def token_bal(self, token, wallet) -> float:
        try:
            c = self.w3.eth.contract(address=Web3.to_checksum_address(token), abi=ERC20_ABI)
            return c.functions.balanceOf(Web3.to_checksum_address(wallet)).call() / 10**c.functions.decimals().call()
        except: return 0.0

    def contract_tx(self, pk, addr, abi, fn, args, value=0, gas=300_000) -> Tuple[bool, str]:
        """Returns (success: bool, message: str)"""
        if not self.ok:
            return False, "No RPC connection"
        try:
            acct      = Account.from_key(pk)
            contract  = self.w3.eth.contract(address=Web3.to_checksum_address(addr), abi=abi)
            func      = getattr(contract.functions, fn)(*args)
            nonce     = self.w3.eth.get_transaction_count(acct.address, "pending")
            gas_price = int(self.w3.eth.gas_price * random.uniform(1.05, 1.15))
            built = func.build_transaction({
                "chainId": CHAIN_ID, "from": acct.address,
                "nonce": nonce, "value": value, "gas": gas, "gasPrice": gas_price
            })
            signed  = self.w3.eth.account.sign_transaction(built, pk)
            tx_hash = self.w3.eth.send_raw_transaction(signed.raw_transaction)
            receipt = self.w3.eth.wait_for_transaction_receipt(tx_hash, timeout=120)
            if receipt.status == 1:
                return True, tx_hash.hex()
            else:
                return False, f"TX reverted on-chain: {tx_hash.hex()}"
        except Exception as e:
            err = str(e).lower()
            if "insufficient" in err: return False, "Insufficient funds — fund wallet from faucet first"
            if "nonce"        in err: return False, f"Nonce error: {str(e)[:80]}"
            return False, str(e)[:120]

    def approve(self, pk, token_addr, spender, amount_wei, gas=100_000) -> Tuple[bool, str]:
        return self.contract_tx(pk, token_addr, ERC20_ABI, "approve", [spender, amount_wei], gas=gas)

# ─── Wallet Manager ───────────────────────────────────────────────────────────
class WalletManager:
    def __init__(self):
        self.wallets = []
        if Path(WALLETS_FILE).exists():
            with open(WALLETS_FILE) as f: self.wallets = json.load(f)

    def save(self):
        with open(WALLETS_FILE, "w") as f: json.dump(self.wallets, f, indent=2)

    def create(self, n) -> list:
        new = []
        for _ in range(n):
            a = Account.create()
            w = {"address": a.address, "private_key": a.key.hex(),
                 "created_at": time.strftime("%Y-%m-%d %H:%M:%S"),
                 "tasks_done": [], "tasks_failed": []}
            self.wallets.append(w); new.append(w)
        self.save(); return new

    def mark_done(self, addr, task):
        for w in self.wallets:
            if w["address"].lower() == addr.lower():
                w.setdefault("tasks_done", [])
                w.setdefault("tasks_failed", [])
                if task not in w["tasks_done"]:
                    w["tasks_done"].append(task)
                # Remove from failed if retrying
                if task in w.get("tasks_failed", []):
                    w["tasks_failed"].remove(task)
        self.save()

    def mark_failed(self, addr, task):
        for w in self.wallets:
            if w["address"].lower() == addr.lower():
                w.setdefault("tasks_failed", [])
                if task not in w["tasks_failed"]:
                    w["tasks_failed"].append(task)
        self.save()

    def is_done(self, addr, task) -> bool:
        for w in self.wallets:
            if w["address"].lower() == addr.lower():
                return task in w.get("tasks_done", [])
        return False

    def reset_task(self, addr, task):
        """Force re-run a task by removing it from done list."""
        for w in self.wallets:
            if w["address"].lower() == addr.lower():
                w.get("tasks_done", []).remove(task) if task in w.get("tasks_done", []) else None
                w.get("tasks_failed", []).remove(task) if task in w.get("tasks_failed", []) else None
        self.save()

    def show_table(self):
        t = Table(title="💼 Saved Wallets", box=box.ROUNDED, style="cyan", header_style="bold magenta")
        t.add_column("#", width=3)
        t.add_column("Address", style="green")
        t.add_column("Private Key", style="yellow")
        t.add_column("Done", style="green")
        t.add_column("Failed", style="red")
        t.add_column("Created", style="dim")
        for i, w in enumerate(self.wallets):
            pk   = w["private_key"][:10] + "…" + w["private_key"][-6:]
            done = len(w.get("tasks_done", []))
            fail_list = w.get("tasks_failed", [])
            t.add_row(str(i+1), w["address"], pk,
                      f"{done}/9",
                      f"{len(fail_list)} ⚠" if fail_list else "0",
                      w["created_at"])
        console.print(t)

