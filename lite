        elif choice == "7":
            console.print(f"[green]✓ Wallets saved to {WALLETS_FILE}[/green]")
            console.print(f"[dim]  {len(wm.wallets)} wallet(s) exported[/dim]")
        
        elif choice == "0":
            console.print("[bold yellow]\n  👋 Goodbye! Good luck with the airdrop!\n[/bold yellow]")
