# ─── Wallet Manager ───────────────────────────────────────────────────────────
class WalletManager:
    def __init__(self):
        self.wallets: list[dict] = []
        self.load()

    def load(self):
        if Path(WALLETS_FILE).exists():
            with open(WALLETS_FILE) as f:
                self.wallets = json.load(f)

    def save(self):
        with open(WALLETS_FILE, "w") as f:
            json.dump(self.wallets, f, indent=2)

    def create(self, count: int = 1) -> list[dict]:
        created = []
        for _ in range(count):
            acct = Account.create()
            wallet = {
                "address": acct.address,
                "private_key": acct.key.hex(),
                "created_at": time.strftime("%Y-%m-%d %H:%M:%S"),
                "tasks_done": [],
            }
            self.wallets.append(wallet)
            created.append(wallet)
        self.save()
        return created

    def list_wallets(self) -> list[dict]:
        return self.wallets

    def get_by_index(self, idx: int) -> Optional[dict]:
        if 0 <= idx < len(self.wallets):
            return self.wallets[idx]
        return None

    def mark_task(self, address: str, task: str):
        for w in self.wallets:
            if w["address"].lower() == address.lower():
                if task not in w.get("tasks_done", []):
                    w.setdefault("tasks_done", []).append(task)
        self.save()

    def display_table(self):
        table = Table(title="💼 Saved Wallets", box=box.ROUNDED,
                      style="cyan", header_style="bold magenta")
        table.add_column("#", style="dim", width=4)
        table.add_column("Address", style="green")
        table.add_column("Private Key", style="yellow")
        table.add_column("Tasks Done", style="blue")
        table.add_column("Created", style="dim")

        for i, w in enumerate(self.wallets):
            pk = w["private_key"][:10] + "..." + w["private_key"][-6:]
            tasks = ", ".join(w.get("tasks_done", [])) or "—"
            table.add_row(str(i+1), w["address"], pk, tasks, w["created_at"])
        console.print(table)


# ─── Web3 Helper ─────────────────────────────────────────────────────────────
class Web3Helper:
    def __init__(self):
        self.w3 = Web3(Web3.HTTPProvider(LITVM_RPC))

    def is_connected(self) -> bool:
        try:
            return self.w3.is_connected()
        except:
            return False

    def get_balance(self, address: str) -> float:
        try:
            bal = self.w3.eth.get_balance(address)
            return float(self.w3.from_wei(bal, "ether"))
        except:
            return 0.0

    def get_nonce(self, address: str) -> int:
        return self.w3.eth.get_transaction_count(address)

    def send_tx(self, private_key: str, tx: dict) -> Optional[str]:
        try:
            signed = self.w3.eth.account.sign_transaction(tx, private_key)
            tx_hash = self.w3.eth.send_raw_transaction(signed.raw_transaction)
            receipt = self.w3.eth.wait_for_transaction_receipt(tx_hash, timeout=120)
            if receipt.status == 1:
                return tx_hash.hex()
            return None
        except Exception as e:
            console.print(f"[red]TX Error: {e}[/red]")
            return None

    def erc20_balance(self, token_addr: str, wallet: str) -> float:
        try:
            contract = self.w3.eth.contract(
                address=Web3.to_checksum_address(token_addr),
                abi=ERC20_ABI
            )
            bal = contract.functions.balanceOf(Web3.to_checksum_address(wallet)).call()
            return float(self.w3.from_wei(bal, "ether"))
        except:
            return 0.0


