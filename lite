        elif choice == "2":
            if not wm.wallets:
                console.print("[yellow]No wallets yet. Create some first.[/yellow]")
            else:
                wm.display_table()
        
        elif choice == "3":
            if not wm.wallets:
                console.print("[red]No wallets found. Create wallets first.[/red]")
                continue
            wm.display_table()
            try:
                idx = int(input(f"{Fore.CYAN}  Select wallet #: {Style.RESET_ALL}")) - 1
                wallet = wm.get_by_index(idx)
                if wallet:
                    te.run_all_tasks(wallet)
                else:
                    console.print("[red]Invalid selection[/red]")
            except ValueError:
                console.print("[red]Invalid input[/red]")
        
        elif choice == "4":
            if not wm.wallets:
                console.print("[red]No wallets found. Create wallets first.[/red]")
                continue
            console.print(f"\n[bold yellow]Running all tasks for {len(wm.wallets)} wallet(s)...[/bold yellow]")
            for i, wallet in enumerate(wm.wallets):
                console.print(f"\n[bold magenta]═══ Wallet {i+1}/{len(wm.wallets)} ═══[/bold magenta]")
                te.run_all_tasks(wallet)
                if i < len(wm.wallets) - 1:
                    wait = random.randint(30, 90)
                    console.print(f"[dim]Waiting {wait}s before next wallet (anti-detection)...[/dim]")
                    time.sleep(wait)
            console.print("\n[bold green]🎉 All wallets processed![/bold green]")
        
        elif choice == "5":
            steps = {
                "1": ("Step 1: LiteForge Faucet",      te.step1_claim_faucet),
                "2": ("Step 2: Lester Labs",            te.step2_launch_token),
                "3": ("Step 3: Midashand Faucet",       te.step3_midashand_faucet),
                "4": ("Step 4: Midashand Bet",          te.step4_place_bet),
                "5": ("Step 5: ONMI Create Token",      te.step5_create_onmi_token),
                "6": ("Step 6: ONMI Swaps",             te.step6_onmi_swaps),
                "7": ("Step 7: ONMI Liquidity",         te.step7_add_liquidity),
