# ─── Chain ───────────────────────────────────────────────────────────────────
class Chain:
    def __init__(self):
        self.w3: Optional[Web3] = None
        for rpc in RPC_URLS:
            try:
                w3 = Web3(Web3.HTTPProvider(rpc, request_kwargs={"timeout":20}))
                if w3.is_connected():
                    self.w3 = w3
                    console.print(f"[green]✓ RPC connected: {rpc}[/green]")
                    return
            except: pass
        console.print("[yellow]⚠ RPC unavailable — tasks will show manual links[/yellow]")

    @property
    def ok(self): return self.w3 is not None

    def balance(self, addr):
        try: return float(self.w3.from_wei(self.w3.eth.get_balance(addr), "ether"))
        except: return 0.0

    def token_bal(self, token, wallet):
        try:
            c   = self.w3.eth.contract(address=Web3.to_checksum_address(token), abi=ERC20_ABI)
            dec = c.functions.decimals().call()
            return c.functions.balanceOf(Web3.to_checksum_address(wallet)).call() / 10**dec
        except: return 0.0

    def send_tx(self, pk: str, to: str, data: bytes = b"",
                value: int = 0, gas: int = 250_000) -> Optional[str]:
        if not self.ok:
            console.print("[dim]    (no RPC — simulated)[/dim]")
            return "0xSIMULATED_" + "ab" * 10
        try:
            acct      = Account.from_key(pk)
            nonce     = self.w3.eth.get_transaction_count(acct.address, "pending")
            gas_price = int(self.w3.eth.gas_price * random.uniform(1.05, 1.15))
            tx = {"chainId": CHAIN_ID, "nonce": nonce,
                  "to": Web3.to_checksum_address(to), "value": value,
                  "gas": gas, "gasPrice": gas_price, "data": data}
            signed  = self.w3.eth.account.sign_transaction(tx, pk)
            tx_hash = self.w3.eth.send_raw_transaction(signed.raw_transaction)
            receipt = self.w3.eth.wait_for_transaction_receipt(tx_hash, timeout=120)
            return tx_hash.hex() if receipt.status == 1 else None
        except Exception as e:
            err = str(e).lower()
            if "insufficient" in err: console.print("[red]    ✗ Insufficient funds — fund wallet first[/red]")
            elif "nonce"       in err: console.print("[yellow]    ⚠ Nonce error[/yellow]")
            else: console.print(f"[red]    TX error: {str(e)[:80]}[/red]")
            return None

    def contract_tx(self, pk: str, addr: str, abi, fn: str,
                    args: list, value: int = 0, gas: int = 300_000) -> Optional[str]:
        if not self.ok:
            console.print("[dim]    (no RPC — simulated)[/dim]")
            return "0xSIMULATED_" + "cd" * 10
        try:
            acct      = Account.from_key(pk)
            contract  = self.w3.eth.contract(address=Web3.to_checksum_address(addr), abi=abi)
            func      = getattr(contract.functions, fn)(*args)
            nonce     = self.w3.eth.get_transaction_count(acct.address, "pending")
            gas_price = int(self.w3.eth.gas_price * random.uniform(1.05, 1.15))
            built = func.build_transaction({"chainId": CHAIN_ID, "from": acct.address,
                "nonce": nonce, "value": value, "gas": gas, "gasPrice": gas_price})
            signed  = self.w3.eth.account.sign_transaction(built, pk)
            tx_hash = self.w3.eth.send_raw_transaction(signed.raw_transaction)
            receipt = self.w3.eth.wait_for_transaction_receipt(tx_hash, timeout=120)
            return tx_hash.hex() if receipt.status == 1 else None
        except Exception as e:
            console.print(f"[red]    Contract error: {str(e)[:100]}[/red]")
            return None

# ─── Wallet Manager ───────────────────────────────────────────────────────────
class WalletManager:
    def __init__(self):
        self.wallets = []
        if Path(WALLETS_FILE).exists():
            with open(WALLETS_FILE) as f: self.wallets = json.load(f)

    def save(self):
        with open(WALLETS_FILE, "w") as f: json.dump(self.wallets, f, indent=2)

    def create(self, n):
        new = []
        for _ in range(n):
            a = Account.create()
            w = {"address": a.address, "private_key": a.key.hex(),
                 "created_at": time.strftime("%Y-%m-%d %H:%M:%S"), "tasks_done": []}
            self.wallets.append(w); new.append(w)
        self.save(); return new

    def mark(self, addr, task):
        for w in self.wallets:
            if w["address"].lower() == addr.lower():
                if task not in w.get("tasks_done", []):
                    w.setdefault("tasks_done", []).append(task)
        self.save()

    def done(self, addr, task):
        for w in self.wallets:
            if w["address"].lower() == addr.lower():
                return task in w.get("tasks_done", [])
        return False

    def table(self):
        t = Table(title="💼 Wallets", box=box.ROUNDED, style="cyan", header_style="bold magenta")
        t.add_column("#", width=4); t.add_column("Address", style="green")
        t.add_column("Key (partial)", style="yellow")
        t.add_column("Progress", style="blue"); t.add_column("Created", style="dim")
        for i, w in enumerate(self.wallets):
            pk = w["private_key"][:10] + "…" + w["private_key"][-6:]
            t.add_row(str(i+1), w["address"], pk,
                      f"{len(w.get('tasks_done',[]))}/9", w["created_at"])
        console.print(t)

# ─── Faucet helper (tries multiple endpoint patterns) ─────────────────────────
def try_faucet(base_url: str, address: str, label: str) -> bool:
    hdrs = {"Content-Type":"application/json",
            "User-Agent":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
            "Origin": base_url, "Referer": base_url + "/"}
    patterns = [
        (base_url.rstrip("/")+"/api/faucet",         {"address": address}),
        (base_url.rstrip("/")+"/api/claim",           {"address": address}),
        (base_url.rstrip("/")+"/api/drip",            {"address": address}),
        (base_url.rstrip("/")+"/faucet/send",         {"toAddress": address}),
        (base_url.rstrip("/")+"/api/faucet/request",  {"walletAddress": address}),
        (base_url.rstrip("/")+"/api/airdrop",         {"address": address}),
    ]
    for url, payload in patterns:
        try:
            r = requests.post(url, json=payload, headers=hdrs, timeout=10)
            if r.status_code in (200, 201):
                console.print(f"[green]  ✓ {label} claimed![/green]")
                return True
            elif r.status_code == 429:
                console.print(f"[yellow]  ⚠ {label} rate-limited (already claimed)[/yellow]")
                return True
        except requests.exceptions.Timeout:
            pass
        except: pass

    console.print(f"[yellow]  ⚠ {label} auto-claim unavailable (site uses wallet-connect)[/yellow]")
    console.print(f"  [dim]→ Claim manually: {base_url}[/dim]")
    return False

