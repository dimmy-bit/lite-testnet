                    console.print(f"[yellow]    ⚠ Task {tid} failed[/yellow]")
                human_delay(2, 4)
        else:
            console.print("[yellow]  ⚠ Manual: https://app.onmi.fun/campaigns/4441?chain=LITVM[/yellow]")

        self.wm.mark(w["address"], "s8")
        human_delay(2, 4)

    # ── STEP 9 ────────────────────────────────────────────────────────────────
    def step9(self, w):
        self._hdr("🔁", "Step 9: AyniLabs — Swap zkLTC→wzkLTC + Supply", w)
        if self.wm.done(w["address"], "s9"):
            console.print("[dim]  ✓ Already done[/dim]"); return

        amt = rand_amt(0.0001, 0.0005)
        console.print(f"  [dim]Amount: {amt} zkLTC[/dim]")

        with console.status("[cyan]  Fetching AyniLabs contracts...[/cyan]", spinner="dots"):
            human_delay(2, 4)
            addrs = fetch_contracts_from_page("https://aynilabs.xyz/dashboard/")
            ayni  = next((a for a in addrs if a.lower() != ZKLTC_TOKEN.lower()), None)

        AYNI_ABI = [
            {"inputs":[{"name":"amount","type":"uint256"}],"name":"wrap",
             "outputs":[],"stateMutability":"nonpayable","type":"function"},
            {"inputs":[{"name":"amount","type":"uint256"}],"name":"supply",
             "outputs":[],"stateMutability":"nonpayable","type":"function"},
            {"inputs":[{"name":"amount","type":"uint256"}],"name":"deposit",
             "outputs":[],"stateMutability":"nonpayable","type":"function"},
        ]

        if ayni and self.chain.ok:
            # Approve
            console.print("  [dim]Approving zkLTC for AyniLabs...[/dim]")
            ap = self.chain.contract_tx(w["private_key"], ZKLTC_TOKEN, ERC20_ABI,
                "approve", [ayni, int(amt * 1e18) * 100], gas=100_000)
            if ap:
                console.print(f"[green]  ✓ Approved. TX: {ap[:16]}...[/green]")
                human_delay(2, 3)
                # Wrap
                wrap_tx = self.chain.contract_tx(w["private_key"], ayni, AYNI_ABI,
                    "wrap", [int(amt * 1e18)], gas=200_000)
                if wrap_tx:
                    console.print(f"[green]  ✓ Wrapped zkLTC→wzkLTC! TX: {wrap_tx[:16]}...[/green]")
                    human_delay(2, 3)
                    # Supply
                    sup_tx = self.chain.contract_tx(w["private_key"], ayni, AYNI_ABI,
                        "supply", [int(amt * 1e18)], gas=200_000)
                    if sup_tx:
                        console.print(f"[green]  ✓ Supplied! TX: {sup_tx[:16]}...[/green]")
                        console.print(f"  [dim]{explorer_tx(sup_tx)}[/dim]")
                    else:
                        # Try deposit as fallback
                        dep_tx = self.chain.contract_tx(w["private_key"], ayni, AYNI_ABI,
                            "deposit", [int(amt * 1e18)], gas=200_000)
                        if dep_tx:
                            console.print(f"[green]  ✓ Deposited! TX: {dep_tx[:16]}...[/green]")
                        else:
                            console.print("[yellow]  ⚠ Supply/deposit failed — visit manually[/yellow]")
                else:
                    console.print("[yellow]  ⚠ Wrap failed — check zkLTC balance[/yellow]")
            else:
                console.print("[yellow]  ⚠ Approve failed[/yellow]")
        else:
            console.print("[yellow]  ⚠ Manual: https://aynilabs.xyz/dashboard/[/yellow]")

        self.wm.mark(w["address"], "s9")
        human_delay(2, 4)

    # ── RUN ALL ───────────────────────────────────────────────────────────────
    def run_all(self, w):
        bal = self.chain.balance(w["address"]) if self.chain.ok else 0
        console.print(f"\n[bold cyan]━━━ {short(w['address'])} | Balance: {bal:.5f} tLTC ━━━[/bold cyan]\n")
        if self.chain.ok and bal < 0.001:
            console.print("[red bold]  ⚠ VERY LOW BALANCE — claim from faucet first![/red bold]")
            console.print("[dim]  → https://liteforge.hub.caldera.xyz[/dim]\n")
        for fn in [self.step1, self.step2, self.step3, self.step4,
                   self.step5, self.step6, self.step7, self.step8, self.step9]:
            fn(w); console.print()
        done = len(w.get("tasks_done", []))
        console.print(f"[bold green]✅ Wallet done! {done}/9 tasks completed.[/bold green]")

# ─── Menu ─────────────────────────────────────────────────────────────────────
def menu():
    print_banner()
    wm    = WalletManager()
    chain = Chain()
    tasks = Tasks(wm, chain)

    STEPS = [
        ("Step 1: LiteForge Faucet",   tasks.step1),
        ("Step 2: Lester Labs Launch",  tasks.step2),
        ("Step 3: Midashand Faucet",    tasks.step3),
        ("Step 4: Midashand Bet",       tasks.step4),
        ("Step 5: ONMI Create Token",   tasks.step5),
        ("Step 6: ONMI Swaps",          tasks.step6),
        ("Step 7: ONMI Liquidity",      tasks.step7),
        ("Step 8: ONMI Campaign",       tasks.step8),
        ("Step 9: AyniLabs",            tasks.step9),
    ]

    while True:
        console.print(Panel(
            "[cyan]1.[/cyan] Create wallets (unlimited)\n"
            "[cyan]2.[/cyan] List saved wallets\n"
            "[cyan]3.[/cyan] Run ALL tasks — single wallet\n"
            "[cyan]4.[/cyan] Run ALL tasks — ALL wallets\n"
            "[cyan]5.[/cyan] Run a specific step\n"
            "[cyan]6.[/cyan] Check wallet balances\n"
            "[cyan]7.[/cyan] Show wallet.json path\n"
            "[cyan]0.[/cyan] Exit",
            title="[bold yellow]⚡ MirLite Bot — Main Menu[/bold yellow]",
            border_style="cyan", expand=False))

        choice = input(f"\n{Fore.CYAN}  Enter choice: {Style.RESET_ALL}").strip()

        if choice == "1":
            try:
                n = int(input(f"{Fore.YELLOW}  How many wallets to create? {Style.RESET_ALL}"))
                created = wm.create(n)
                console.print(f"\n[green]✓ Created {n} wallet(s):[/green]")
                for cw in created:
                    console.print(f"  [green]{cw['address']}[/green]")
                console.print(f"\n[bold yellow]⚠ Back up {WALLETS_FILE} — it contains private keys![/bold yellow]")
            except ValueError: console.print("[red]Invalid number[/red]")

        elif choice == "2":
            if not wm.wallets: console.print("[yellow]No wallets yet.[/yellow]")
            else: wm.table()

        elif choice == "3":
            if not wm.wallets: console.print("[red]No wallets. Create some first.[/red]"); continue
            wm.table()
            try:
                idx = int(input(f"{Fore.CYAN}  Wallet #: {Style.RESET_ALL}")) - 1
                if 0 <= idx < len(wm.wallets): tasks.run_all(wm.wallets[idx])
                else: console.print("[red]Invalid[/red]")
            except (ValueError, IndexError): console.print("[red]Invalid[/red]")

        elif choice == "4":
            if not wm.wallets: console.print("[red]No wallets.[/red]"); continue
            console.print(f"\n[bold yellow]Processing {len(wm.wallets)} wallet(s)...[/bold yellow]")
            for i, w in enumerate(wm.wallets):
                console.print(f"\n[bold magenta]═══ Wallet {i+1}/{len(wm.wallets)} ═══[/bold magenta]")
                tasks.run_all(w)
                if i < len(wm.wallets) - 1:
                    wait = random.randint(45, 120)
                    console.print(f"[dim]Cooling down {wait}s (anti-detection)...[/dim]")
                    time.sleep(wait)
            console.print("\n[bold green]🎉 All wallets processed![/bold green]")

        elif choice == "5":
            console.print()
            for i, (name, _) in enumerate(STEPS):
                console.print(f"  [cyan]{i+1}.[/cyan] {name}")
            try:
                s = int(input(f"\n{Fore.CYAN}  Step #: {Style.RESET_ALL}")) - 1
                if not (0 <= s < len(STEPS)): console.print("[red]Invalid step[/red]"); continue
                if not wm.wallets: console.print("[red]No wallets.[/red]"); continue
                wm.table()
                wc = input(f"{Fore.CYAN}  Wallet # (or 'all'): {Style.RESET_ALL}").strip().lower()
                fn = STEPS[s][1]
                if wc == "all":
                    for w in wm.wallets: fn(w); human_delay(5, 15)
                else:
                    idx = int(wc) - 1
                    if 0 <= idx < len(wm.wallets): fn(wm.wallets[idx])
                    else: console.print("[red]Invalid[/red]")
            except (ValueError, IndexError): console.print("[red]Invalid input[/red]")

        elif choice == "6":
            if not wm.wallets: console.print("[yellow]No wallets.[/yellow]"); continue
            t = Table(title="💰 Balances", box=box.ROUNDED, style="cyan", header_style="bold magenta")
            t.add_column("#"); t.add_column("Address"); t.add_column("tLTC")
            t.add_column("zkLTC"); t.add_column("Tasks")
            with console.status("[cyan]Fetching...[/cyan]", spinner="dots"):
                for i, w in enumerate(wm.wallets):
                    b1 = chain.balance(w["address"]) if chain.ok else 0.0
                    b2 = chain.token_bal(ZKLTC_TOKEN, w["address"]) if chain.ok else 0.0
                    t.add_row(str(i+1), short(w["address"]),
                              f"{b1:.5f}", f"{b2:.4f}",
                              f"{len(w.get('tasks_done',[]))}/9")
            console.print(t)

        elif choice == "7":
            path = Path(WALLETS_FILE).resolve()
            console.print(f"[green]Wallets saved at: {path}[/green]")

        elif choice == "0":
            console.print("[bold yellow]\n  👋 Good luck with the airdrop!\n[/bold yellow]")
            sys.exit(0)

        else:
            console.print("[red]Invalid choice[/red]")

        input(f"\n{Fore.CYAN}  Press Enter to continue...{Style.RESET_ALL}")
        os.system("cls" if os.name == "nt" else "clear")
        print_banner()

if __name__ == "__main__":
    try: menu()
    except KeyboardInterrupt:
        console.print("\n[bold yellow]\n  Interrupted. Bye!\n[/bold yellow]"); sys.exit(0)
