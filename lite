                console.print(f"  [cyan]{k}.[/cyan] {name}")
            
            step_choice = input(f"\n{Fore.CYAN}  Select step: {Style.RESET_ALL}").strip()
            if step_choice not in steps:
                console.print("[red]Invalid step[/red]")
                continue
            
            if not wm.wallets:
                console.print("[red]No wallets found[/red]")
                continue
            
            wm.display_table()
            wallet_choice = input(f"{Fore.CYAN}  Select wallet # (or 'all'): {Style.RESET_ALL}").strip()
            
            step_fn = steps[step_choice][1]
            if wallet_choice.lower() == "all":
                for w in wm.wallets:
                    step_fn(w)
                    human_delay(5, 15)
            else:
