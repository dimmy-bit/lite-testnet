def fetch_contracts(url: str) -> list:
    try:
        r = requests.get(url, headers={"User-Agent":"Mozilla/5.0 (Windows NT 10.0; Win64; x64)"}, timeout=12)
        seen, out = set(), []
        for a in re.findall(r'0x[a-fA-F0-9]{40}', r.text):
            if a.lower() not in seen and a.lower() != "0x"+"0"*40:
                seen.add(a.lower()); out.append(a)
        return out
    except Exception as e:
        info(f"Page fetch error: {str(e)[:60]}")
        return []

