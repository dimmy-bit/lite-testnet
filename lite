        console.print(f"  [dim]Doing {swap_count} swaps...[/dim]")

        with console.status("[cyan]  Scanning ONMI swap page...[/cyan]", spinner="dots"):
            human_delay(1, 2)
            addrs = fetch_contracts("https://app.onmi.fun/swap?chain=LITVM")
            router = next((a for a in addrs if a.lower() != ZKLTC_TOKEN.lower()), None)

        SWAP_ABI = [{"inputs":[
                {"name":"amountOutMin","type":"uint256"},
                {"name":"path","type":"address[]"},
                {"name":"to","type":"address"},
                {"name":"deadline","type":"uint256"}],
            "name":"swapExactETHForTokens",
            "outputs":[{"name":"amounts","type":"uint256[]"}],
            "stateMutability":"payable","type":"function"}]

        if not router or not self.chain.ok:
            fail("Router not found — manual swaps required")
            info("→ Visit: https://app.onmi.fun/swap?chain=LITVM")
            self.wm.mark_failed(w["address"], "s6"); return False

        done_count = 0
        for i in range(swap_count):
            amt = rand_amt()
            console.print(f"\n  [dim]Swap {i+1}/{swap_count}: {amt} tLTC → zkLTC[/dim]")
            deadline = int(time.time()) + 300
            success, result = self.chain.contract_tx(
                w["private_key"], router, SWAP_ABI,
                "swapExactETHForTokens",
                [0, [router, ZKLTC_TOKEN], w["address"], deadline],
                value=int(amt * 1e18), gas=250_000)
            if success:
                ok(f"Swap {i+1} done! TX: {result[:16]}...")
                done_count += 1
            else:
                fail(f"Swap {i+1} failed: {result}")
            human_delay(2, 5)

        if done_count == swap_count:
            ok(f"All {swap_count} swaps successful!")
            self.wm.mark_done(w["address"], "s6"); return True
        elif done_count > 0:
            warn(f"Partial: {done_count}/{swap_count} swaps done")
            self.wm.mark_done(w["address"], "s6"); return True
        else:
            fail("All swaps failed")
            self.wm.mark_failed(w["address"], "s6"); return False

    # ══════════════════════════════════════════════════════════════════════════
    # STEP 7 — ONMI Add Liquidity
    # ══════════════════════════════════════════════════════════════════════════
    def step7(self, w: dict, force=False):
        self._header("💧", "Step 7: ONMI — Add Liquidity", w)
        if self.wm.is_done(w["address"], "s7") and not force:
            warn("Already completed."); return True

        amt_eth   = rand_amt(0.0001, 0.0005)
        amt_token = rand_amt(0.0001, 0.0005)
        liq_url   = f"https://app.onmi.fun/liquidity/add/ZKLTC/{ZKLTC_TOKEN}?chain=LITVM"
        console.print(f"  [dim]{amt_eth} tLTC + {amt_token} zkLTC[/dim]")

        with console.status("[cyan]  Scanning liquidity page...[/cyan]", spinner="dots"):
            human_delay(2, 3)
            addrs  = fetch_contracts(liq_url)
            router = next((a for a in addrs if a.lower() != ZKLTC_TOKEN.lower()), None)

        ADD_LIQ_ABI = [{"inputs":[
                {"name":"token","type":"address"},
                {"name":"amountTokenDesired","type":"uint256"},
                {"name":"amountTokenMin","type":"uint256"},
                {"name":"amountETHMin","type":"uint256"},
                {"name":"to","type":"address"},
                {"name":"deadline","type":"uint256"}],
            "name":"addLiquidityETH",
            "outputs":[{"name":"a","type":"uint256"},{"name":"b","type":"uint256"},
                       {"name":"liq","type":"uint256"}],
            "stateMutability":"payable","type":"function"}]

        if not router or not self.chain.ok:
            fail("Router not found — manual liquidity required")
            info(f"→ Visit: {liq_url}")
            self.wm.mark_failed(w["address"], "s7"); return False

        # Approve zkLTC first
        info("Approving zkLTC for router...")
        ap_ok, ap_res = self.chain.approve(
            w["private_key"], ZKLTC_TOKEN, router,
            int(amt_token * 1e18) * 100)

        if not ap_ok:
            fail(f"Approve failed: {ap_res}")
            self.wm.mark_failed(w["address"], "s7"); return False

        ok(f"Approved. TX: {ap_res[:16]}...")
        human_delay(2, 4)

        deadline = int(time.time()) + 300
        success, result = self.chain.contract_tx(
            w["private_key"], router, ADD_LIQ_ABI,
            "addLiquidityETH",
            [ZKLTC_TOKEN, int(amt_token*1e18), 0, 0, w["address"], deadline],
            value=int(amt_eth * 1e18), gas=400_000)

        if success:
            ok(f"Liquidity added! TX: {result[:20]}...")
            info(tx_url(result))
            self.wm.mark_done(w["address"], "s7"); return True
        else:
            fail(f"Add liquidity failed: {result}")
            info(f"→ Visit: {liq_url}")
            self.wm.mark_failed(w["address"], "s7"); return False

    # ══════════════════════════════════════════════════════════════════════════
