def fetch_contracts_from_page(url: str) -> list:
    """Scrape EVM contract addresses from a webpage."""
    try:
        r = requests.get(url, headers={"User-Agent":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
            "AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36"},
            timeout=12)
        addrs = re.findall(r'0x[a-fA-F0-9]{40}', r.text)
        # Filter out zero-address and duplicates
        seen, result = set(), []
        for a in addrs:
            if a.lower() != "0x"+"0"*40 and a.lower() not in seen:
                seen.add(a.lower()); result.append(a)
        return result
    except Exception as e:
        console.print(f"[dim]  Page fetch failed: {str(e)[:50]}[/dim]")
        return []

